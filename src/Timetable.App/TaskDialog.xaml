<Window x:Class="Timetable.App.TaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.Resources>
            <Style TargetType="TextBlock" x:Key="Label">
                <Setter Property="Margin" Value="0,10,0,3" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
        </Grid.Resources>

        <StackPanel>
            <TextBlock Text="Titel" Style="{StaticResource Label}" Margin="0,0,0,3" />
            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Status" Style="{StaticResource Label}" />
            <ComboBox ItemsSource="{Binding StatusChoices}" DisplayMemberPath="Label"
                      SelectedItem="{Binding SelectedStatus}" Width="160" HorizontalAlignment="Left" />
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Zeitraum" Style="{StaticResource Label}" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Von" VerticalAlignment="Center" Margin="0,0,6,0" />
                <DatePicker SelectedDate="{Binding StartDate}" Width="140" />
                <TextBlock Text="bis" VerticalAlignment="Center" Margin="10,0,6,0" />
                <DatePicker SelectedDate="{Binding EndDate}" Width="140" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="3">
            <TextBlock Text="Zugeordnet (wer)" Style="{StaticResource Label}" />
            <ItemsControl ItemsSource="{Binding Assignees}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Person.ShortCode}"
                                  ToolTip="{Binding Person.DisplayName}" Margin="0,2,12,2" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <DockPanel Grid.Row="4" Margin="0,16,0,0">
            <Button x:Name="DeleteButton" Content="Löschen" Padding="12,5"
                    Foreground="#B22222" Click="Delete_Click" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" IsDefault="True" Padding="16,5" Margin="0,0,8,0" Click="Save_Click" />
                <Button Content="Abbrechen" IsCancel="True" Padding="12,5" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
