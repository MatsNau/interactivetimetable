<Window x:Class="Timetable.App.PeopleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Personen verwalten"
        Width="440" Height="460" MinWidth="360" MinHeight="320"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <DockPanel Margin="14">
        <DockPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="Hinzufügen" Padding="12,5" Margin="0,0,8,0" Command="{Binding AddCommand}" />
                <Button Content="Entfernen" Padding="12,5" Foreground="#B22222" Click="Remove_Click" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" IsDefault="True" Padding="16,5" Margin="0,0,8,0" Click="Save_Click" />
                <Button Content="Abbrechen" IsCancel="True" Padding="12,5" />
            </StackPanel>
        </DockPanel>

        <DataGrid ItemsSource="{Binding People}" SelectedItem="{Binding SelectedPerson}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E0E0E0"
                  RowHeight="24" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kürzel" Width="90"
                                    Binding="{Binding ShortCode, UpdateSourceTrigger=PropertyChanged}" />
                <DataGridTextColumn Header="Name" Width="*"
                                    Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
